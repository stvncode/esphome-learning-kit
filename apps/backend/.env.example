# Postgres connection string
DATABASE_URL=postgres://postgres:postgres@localhost:5432/esphome_learning_kit

# Generate one with: openssl rand -base64 32
BETTER_AUTH_SECRET=

# Base URL of the backend
BETTER_AUTH_URL=http://localhost:3001

# Comma-separated origins allowed to call the auth API (e.g. the frontend)
TRUSTED_ORIGINS=http://localhost:5173

# Email (optional) — password-reset emails are sent via Resend when both are set.
# Without them, the reset link is logged to the backend console (fine for dev).
RESEND_API_KEY=
EMAIL_FROM="steven.travers@openhomefoundation.org"
